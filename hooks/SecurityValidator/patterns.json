  "paths": {
    "zeroAccess": [
      "~/.ssh/id_*",
      "~/.ssh/*.pem",
      "~/.aws/credentials",
      "~/.gnupg/private*",
      "**/credentials.json",
      "**/service-account*.json"
    ],
    "readOnly": [
      "/etc/**"
    ],
    "confirmWrite": [
      "~/.claude/settings.json",
      "**/.env",
      "**/.env.local",
      "**/.env.production",
      "**/.env.staging",
      "**/.env.development",
      "~/.ssh/*"
    ],
    "noDelete": [
      "~/.claude/hooks/**",
      "~/.claude/PAI/**",
      ".git/**",
      "LICENSE*",
      "README.md"
    ]
