{
  "name": "saintpepsi-claude-code-hooks",
  "version": "1.0.0",
  "scripts": {
    "install-hooks": "bun run install.ts",
    "uninstall-hooks": "bun run uninstall.ts",
    "export-settings": "bun run scripts/export-hooks.ts",
    "import-settings": "bun run scripts/import-hooks.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "docs:render": "bun run scripts/docs/render.ts",
    "docs:check": "bun run scripts/docs/check.ts",
    "prepare": "husky",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "format": "bunx biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/bun": "^1.3.10",
    "husky": "^9.0.0"
  },
  "dependencies": {
    "yaml": "^2.8.2"
  }
}
