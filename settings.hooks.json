{
  "envVar": "SAINTPEPSI_PAI_HOOKS_DIR",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/BashWriteGuard.hook.ts"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/DestructiveDeleteGuard.hook.ts"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/DestructiveDeleteGuard.hook.ts"
          },
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/TypeStrictness.hook.ts"
          },
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/CodingStandardsEnforcer.hook.ts"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/DestructiveDeleteGuard.hook.ts"
          },
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/TypeStrictness.hook.ts"
          },
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/CodingStandardsEnforcer.hook.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/CodingStandardsAdvisor.hook.ts"
          }
        ]
      },
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/WorktreeSafetyVerification.hook.ts"
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/ArchitectureEscalation.hook.ts"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/CodeQualityGuard.hook.ts"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/CodeQualityGuard.hook.ts"
          },
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/HookExecutePermission.hook.ts"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/CodeQualityBaseline.hook.ts"
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/CitationTracker.hook.ts"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/CitationTracker.hook.ts"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/CitationTracker.hook.ts"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/CitationEnforcement.hook.ts"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/CitationEnforcement.hook.ts"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/TestObligationTracker.hook.ts"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/TestObligationTracker.hook.ts"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/DocObligationTracker.hook.ts"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/DocObligationTracker.hook.ts"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/TestObligationTracker.hook.ts"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/GitAutoSync.hook.ts"
          },
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/SessionQualityReport.hook.ts"
          },
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/LearningActioner.hook.ts"
          },
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/ModeAnalytics.hook.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/CheckAlgorithmVersion.hook.ts"
          },
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/BranchAwareness.hook.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/LastResponseCache.hook.ts"
          },
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/TestObligationEnforcer.hook.ts"
          },
          {
            "type": "command",
            "command": "${SAINTPEPSI_PAI_HOOKS_DIR}/hooks/DocObligationEnforcer.hook.ts"
          }
        ]
      }
    ]
  }
}
