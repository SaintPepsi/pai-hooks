{
  "$schema": "https://biomejs.dev/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "noDescendingSpecificity": "off"
      },
      "suspicious": {
        "noTemplateCurlyInString": "off",
        "noExplicitAny": "off",
        "noAssignInExpressions": "off",
        "noImplicitAnyLet": "off",
        "useIterableCallbackReturn": "off"
      },
      "complexity": {
        "noBannedTypes": "off"
      },
      "correctness": {
        "noEmptyCharacterClassInRegex": "off"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!node_modules",
      "!dist",
      "!test-fixtures",
      "!docs",
      "!scripts/docs",
      "!coverage",
      "!.duplication-index.json"
    ]
  }
}
